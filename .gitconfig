[include]
    path = .gitconfig.local
[core]
    excludesfile = ~/.gitignore
    editor = nvim
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    features = side-by-side line-numbers decorations
    whitespace-error-style = 22 reverse
    colorMoved = default
	syntax-theme = tokyonight-1337
	minus-style = "syntax \"#3a1830\""
	minus-emph-style = "black #900048"
	plus-style = "syntax \"#1a3a2a\""
	plus-emph-style = "black #2ac3de"
	line-numbers-minus-style = "#ff0e82"
	line-numbers-plus-style = "#2ac3de"
	line-numbers-zero-style = "#565f89"
	commit-decoration-style = "bold #EDFF00 box ul"
	file-style = "bold #7c3aed ul"
	hunk-header-decoration-style = "#ff0e82 box"
	hunk-header-style = "file line-number #7c3aed"
    # colors set dynamically in .zshrc from COLOR_* vars
[delta "decorations"]
    file-decoration-style = none
    # colors set dynamically in .zshrc from COLOR_* vars
[merge]
    keepBackup = false
	tool = nvimdiff
    ff = false
[mergetool "p4merge"]
    cmd = p4merge "$BASE" "$LOCAL" "$REMOTE" "$MERGED"
    keepBackup = false
    keepTemporaries = false
    trustExitCode = false
    prompt = false
[diff]
	tool = nvimdiff
    renames = copies
    mnemonicprefix = true
[difftool "p4diff"]
    cmd = p4diff "$LOCAL" "$REMOTE"
    prompt = false
[pull]
    rebase = true
[push]
    default = current
    followTags = true
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[fetch]
    prune = true
[alias]
  # reset
    unstage = reset HEAD              # remove files from index (tracking)
    uncommit = reset --soft HEAD^     # go back before last commit, with files in uncommitted state
    delete-remote-tag = push --delete origin
    nehma = checkout
	stash = stash --all
[rerere]
	enabled = true
[include]
    path = ~/.gitconfig.local
[includeIf "gitdir:~/.dotfiles/"]
    path = ~/.dotfiles/.gitconfig.local
# [color "status"] and [color "decorate"] set by install script from colors.sh
[color "status"]
	added = "#2ac3de"
	changed = "#EDFF00"
	untracked = "#ff0e82"
[color "decorate"]
	branch = "#2ac3de"
	remoteBranch = "#7c3aed"
	tag = "#EDFF00"
	HEAD = "bold #ff0e82"
[difftool "nvimdiff"]
	cmd = nvim -d \"$LOCAL\" \"$REMOTE\"
[difftool]
	prompt = false
[color "branch"]
	current = "#2ac3de"
	local = "#cdd6f4"
	remote = "#7c3aed"
[coderabbit]
	machineId = cli/be19af57f0044bb0a13e90e9db2bc19e
