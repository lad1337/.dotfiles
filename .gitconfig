[include]
    path = .gitconfig.local
[core]
    excludesfile = ~/.gitignore
    editor = nvim
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    features = side-by-side line-numbers decorations
    whitespace-error-style = 22 reverse
    colorMoved = default
    syntax-theme = none
	minus-style = "syntax \"#3a1830\""
	minus-emph-style = "black #900048"
	plus-style = "syntax \"#1a3a2a\""
	plus-emph-style = "black #00ffb7"
	line-numbers-minus-style = "#ff0e82"
	line-numbers-plus-style = "#00ffb7"
	line-numbers-zero-style = "#565f89"
	commit-decoration-style = "bold #EDFF00 box ul"
	file-style = "bold #cba6f7 ul"
	hunk-header-decoration-style = "#ff0e82 box"
	hunk-header-style = "file line-number #cba6f7"
    # colors set dynamically in .zshrc from COLOR_* vars
[delta "decorations"]
    file-decoration-style = none
    # colors set dynamically in .zshrc from COLOR_* vars
[merge]
    keepBackup = false
	tool = nvimdiff
    ff = false
[mergetool "p4merge"]
    cmd = p4merge "$BASE" "$LOCAL" "$REMOTE" "$MERGED"
    keepBackup = false
    keepTemporaries = false
    trustExitCode = false
    prompt = false
[diff]
    tool = p4diff
    renames = copies
    mnemonicprefix = true
[difftool "p4diff"]
    cmd = p4diff "$LOCAL" "$REMOTE"
    prompt = false
[pull]
    rebase = true
[push]
    default = current
    followTags = true
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[fetch]
    prune = true
[alias]
  # reset
    unstage = reset HEAD              # remove files from index (tracking)
    uncommit = reset --soft HEAD^     # go back before last commit, with files in uncommitted state
    delete-remote-tag = push --delete origin
    nehma = checkout
	stash = stash --all
[rerere]
	enabled = true
[include]
    path = ~/.gitconfig.local
[includeIf "gitdir:~/.dotfiles/"]
    path = ~/.dotfiles/.gitconfig.local
# [color "status"] set dynamically in .zshrc from COLOR_* vars
[color "status"]
	added = "#00ffb7"
	changed = "#EDFF00"
	untracked = "#ff0e82"
