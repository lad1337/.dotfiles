#!/usr/bin/env bash
#
# Bake colors from colors.sh into all config files
# Run this after changing colors.sh or during dotbot install
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"

# Source colors
source "$DOTFILES_DIR/colors.sh"

echo "Baking colors from colors.sh..."
echo "  FG:       $COLOR_FG"
echo "  Magenta:  $COLOR_MAGENTA"
echo "  Magenta2: $COLOR_MAGENTA2"
echo "  Cyan:     $COLOR_CYAN"
echo "  Purple:   $COLOR_PURPLE"
echo "  Yellow:   $COLOR_YELLOW"

# Derived colors
MINUS_BG="#3a1830"      # dark magenta tint for diff
PLUS_BG="#1a3a2a"       # dark cyan tint for diff
COLOR_MUTED="#565f89"   # muted for comments, unchanged lines
COLOR_BG="#1a1b26"      # background

# Helper: convert hex to RGB floats for iTerm2 plist
hex_to_rgb_floats() {
  local hex="${1#\#}"
  local r=$((16#${hex:0:2}))
  local g=$((16#${hex:2:2}))
  local b=$((16#${hex:4:2}))
  printf "%.16f %.16f %.16f" "$(echo "scale=16; $r/255" | bc)" "$(echo "scale=16; $g/255" | bc)" "$(echo "scale=16; $b/255" | bc)"
}

# Helper: generate iTerm2 color dict entry
iterm_color_dict() {
  local name="$1"
  local hex="$2"
  read -r r g b <<< "$(hex_to_rgb_floats "$hex")"
  cat << EOF
	<key>$name</key>
	<dict>
		<key>Alpha Component</key>
		<real>1</real>
		<key>Blue Component</key>
		<real>$b</real>
		<key>Color Space</key>
		<string>sRGB</string>
		<key>Green Component</key>
		<real>$g</real>
		<key>Red Component</key>
		<real>$r</real>
	</dict>
EOF
}

echo ""
echo "Updating git config..."

# Delta settings
git config --global delta.minus-style "syntax \"$MINUS_BG\""
git config --global delta.minus-emph-style "black $COLOR_MAGENTA2"
git config --global delta.plus-style "syntax \"$PLUS_BG\""
git config --global delta.plus-emph-style "black $COLOR_CYAN"
git config --global delta.line-numbers-minus-style "$COLOR_MAGENTA"
git config --global delta.line-numbers-plus-style "$COLOR_CYAN"
git config --global delta.line-numbers-zero-style "$COLOR_MUTED"
git config --global delta.commit-decoration-style "bold $COLOR_YELLOW box ul"
git config --global delta.file-style "bold $COLOR_PURPLE ul"
git config --global delta.hunk-header-decoration-style "$COLOR_MAGENTA box"
git config --global delta.hunk-header-style "file line-number $COLOR_PURPLE"

# Git status colors
git config --global color.status.added "$COLOR_CYAN"
git config --global color.status.changed "$COLOR_YELLOW"
git config --global color.status.untracked "$COLOR_MAGENTA"

# Git branch colors
git config --global color.branch.current "$COLOR_CYAN"
git config --global color.branch.local "$COLOR_FG"
git config --global color.branch.remote "$COLOR_PURPLE"

# Git log decorate colors
git config --global color.decorate.branch "$COLOR_CYAN"
git config --global color.decorate.remoteBranch "$COLOR_PURPLE"
git config --global color.decorate.tag "$COLOR_YELLOW"
git config --global color.decorate.HEAD "bold $COLOR_MAGENTA"

echo ""
echo "Updating lazygit config..."
cat > "$DOTFILES_DIR/config/lazygit/config.yml" << EOF
git:
  paging:
    colorArg: always
    pager: delta --dark --paging=never
gui:
  skipDiscardChangeWarning: true
  theme:
    activeBorderColor:
      - "$COLOR_YELLOW"
      - bold
    inactiveBorderColor:
      - "$COLOR_MUTED"
    optionsTextColor:
      - "$COLOR_PURPLE"
    selectedLineBgColor:
      - "$COLOR_MAGENTA2"
    cherryPickedCommitBgColor:
      - "$COLOR_MAGENTA2"
    cherryPickedCommitFgColor:
      - "$COLOR_CYAN"
    unstagedChangesColor:
      - "$COLOR_MAGENTA"
    defaultFgColor:
      - "$COLOR_FG"
    searchingActiveBorderColor:
      - "$COLOR_YELLOW"
EOF
echo "  Updated: config/lazygit/config.yml"

echo ""
echo "Updating k9s skin..."
cat > "$DOTFILES_DIR/config/k9s/skins/tokyonight-1337.yaml" << EOF
# TokyoNight-1337 skin for k9s - generated by bake-colors
k9s:
  body:
    fgColor: "$COLOR_FG"
    bgColor: default
    logoColor: "$COLOR_YELLOW"
  prompt:
    fgColor: "$COLOR_FG"
    bgColor: default
    suggestColor: "$COLOR_PURPLE"
  info:
    fgColor: "$COLOR_PURPLE"
    sectionColor: "$COLOR_CYAN"
  dialog:
    fgColor: "$COLOR_FG"
    bgColor: default
    buttonFgColor: "$COLOR_BG"
    buttonBgColor: "$COLOR_PURPLE"
    buttonFocusFgColor: "$COLOR_BG"
    buttonFocusBgColor: "$COLOR_YELLOW"
    labelFgColor: "$COLOR_MAGENTA"
    fieldFgColor: "$COLOR_FG"
  frame:
    border:
      fgColor: "$COLOR_MAGENTA2"
      focusColor: "$COLOR_YELLOW"
    menu:
      fgColor: "$COLOR_FG"
      keyColor: "$COLOR_MAGENTA"
      numKeyColor: "$COLOR_MAGENTA"
    crumbs:
      fgColor: "$COLOR_BG"
      bgColor: "$COLOR_PURPLE"
      activeColor: "$COLOR_YELLOW"
    status:
      newColor: "$COLOR_CYAN"
      modifyColor: "$COLOR_YELLOW"
      addColor: "$COLOR_CYAN"
      pendingColor: "$COLOR_PURPLE"
      errorColor: "$COLOR_MAGENTA"
      highlightColor: "$COLOR_PURPLE"
      killColor: "$COLOR_MAGENTA2"
      completedColor: "$COLOR_MUTED"
    title:
      fgColor: "$COLOR_FG"
      bgColor: default
      highlightColor: "$COLOR_YELLOW"
      counterColor: "$COLOR_PURPLE"
      filterColor: "$COLOR_MAGENTA"
  views:
    charts:
      bgColor: default
      defaultDialColors:
        - "$COLOR_CYAN"
        - "$COLOR_MAGENTA"
      defaultChartColors:
        - "$COLOR_CYAN"
        - "$COLOR_MAGENTA"
    table:
      fgColor: "$COLOR_FG"
      bgColor: default
      cursorFgColor: "$COLOR_BG"
      cursorBgColor: "$COLOR_PURPLE"
      markColor: "$COLOR_YELLOW"
      header:
        fgColor: "$COLOR_CYAN"
        bgColor: default
        sorterColor: "$COLOR_YELLOW"
    xray:
      fgColor: "$COLOR_FG"
      bgColor: default
      cursorColor: "$COLOR_PURPLE"
      graphicColor: "$COLOR_YELLOW"
      showIcons: false
    yaml:
      keyColor: "$COLOR_CYAN"
      colonColor: "$COLOR_MUTED"
      valueColor: "$COLOR_FG"
    logs:
      fgColor: "$COLOR_FG"
      bgColor: default
      indicator:
        fgColor: "$COLOR_PURPLE"
        bgColor: default
        toggleOnColor: "$COLOR_CYAN"
        toggleOffColor: "$COLOR_MUTED"
EOF
echo "  Updated: config/k9s/skins/tokyonight-1337.yaml"

echo ""
echo "Updating bat theme..."
cat > "$DOTFILES_DIR/config/bat/themes/tokyonight-1337.tmTheme" << 'XMLHEAD'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>name</key>
	<string>TokyoNight Custom</string>
	<key>settings</key>
	<array>
		<dict>
			<key>settings</key>
			<dict>
				<key>background</key>
XMLHEAD
cat >> "$DOTFILES_DIR/config/bat/themes/tokyonight-1337.tmTheme" << EOF
				<string>$COLOR_BG</string>
				<key>foreground</key>
				<string>$COLOR_FG</string>
				<key>caret</key>
				<string>$COLOR_YELLOW</string>
				<key>selection</key>
				<string>$COLOR_MAGENTA2</string>
				<key>lineHighlight</key>
				<string>#292e42</string>
				<key>findHighlight</key>
				<string>$COLOR_YELLOW</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Comment</string>
			<key>scope</key>
			<string>comment, punctuation.definition.comment</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_MUTED</string>
				<key>fontStyle</key>
				<string>italic</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>String</string>
			<key>scope</key>
			<string>string, constant.other.symbol</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_CYAN</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Number</string>
			<key>scope</key>
			<string>constant.numeric</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>#ff9e64</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Constant</string>
			<key>scope</key>
			<string>constant, constant.language, constant.character</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>#ff9e64</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Keyword</string>
			<key>scope</key>
			<string>keyword, storage.type, storage.modifier</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_MAGENTA</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Function</string>
			<key>scope</key>
			<string>entity.name.function, support.function</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_PURPLE</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Class</string>
			<key>scope</key>
			<string>entity.name.class, entity.name.type, support.class</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_YELLOW</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Variable</string>
			<key>scope</key>
			<string>variable, variable.parameter</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_FG</string>
			</dict>
		</dict>
		<dict>
			<key>name</key>
			<string>Punctuation</string>
			<key>scope</key>
			<string>punctuation</string>
			<key>settings</key>
			<dict>
				<key>foreground</key>
				<string>$COLOR_MUTED</string>
			</dict>
		</dict>
	</array>
</dict>
</plist>
EOF
echo "  Updated: config/bat/themes/tokyonight-1337.tmTheme"

# Rebuild bat cache if bat is installed
if command -v bat &> /dev/null; then
  echo ""
  echo "Rebuilding bat cache..."
  bat cache --build
fi

echo ""
echo "Updating iTerm2 colorscheme..."
mkdir -p "$DOTFILES_DIR/config/iterm"
{
  echo '<?xml version="1.0" encoding="UTF-8"?>'
  echo '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">'
  echo '<plist version="1.0">'
  echo '<dict>'
  # ANSI colors (0-15)
  # 0: Black (bg), 1: Red (magenta), 2: Green (cyan), 3: Yellow
  # 4: Blue (purple), 5: Magenta, 6: Cyan, 7: White (fg)
  # 8-15: Bright versions
  iterm_color_dict "Ansi 0 Color" "$COLOR_BG"
  iterm_color_dict "Ansi 1 Color" "$COLOR_MAGENTA"
  iterm_color_dict "Ansi 2 Color" "$COLOR_CYAN"
  iterm_color_dict "Ansi 3 Color" "$COLOR_YELLOW"
  iterm_color_dict "Ansi 4 Color" "$COLOR_PURPLE"
  iterm_color_dict "Ansi 5 Color" "$COLOR_MAGENTA"
  iterm_color_dict "Ansi 6 Color" "$COLOR_CYAN"
  iterm_color_dict "Ansi 7 Color" "$COLOR_FG"
  iterm_color_dict "Ansi 8 Color" "$COLOR_MUTED"
  iterm_color_dict "Ansi 9 Color" "$COLOR_MAGENTA"
  iterm_color_dict "Ansi 10 Color" "$COLOR_CYAN"
  iterm_color_dict "Ansi 11 Color" "$COLOR_YELLOW"
  iterm_color_dict "Ansi 12 Color" "$COLOR_PURPLE"
  iterm_color_dict "Ansi 13 Color" "$COLOR_MAGENTA"
  iterm_color_dict "Ansi 14 Color" "$COLOR_CYAN"
  iterm_color_dict "Ansi 15 Color" "$COLOR_FG"
  # Special colors
  iterm_color_dict "Background Color" "$COLOR_BG"
  iterm_color_dict "Foreground Color" "$COLOR_FG"
  iterm_color_dict "Bold Color" "$COLOR_FG"
  iterm_color_dict "Cursor Color" "$COLOR_YELLOW"
  iterm_color_dict "Cursor Text Color" "$COLOR_BG"
  iterm_color_dict "Selection Color" "$COLOR_MAGENTA2"
  iterm_color_dict "Selected Text Color" "$COLOR_FG"
  iterm_color_dict "Link Color" "$COLOR_CYAN"
  echo '</dict>'
  echo '</plist>'
} > "$DOTFILES_DIR/config/iterm/tokyonight-1337.itermcolors"
echo "  Updated: config/iterm/tokyonight-1337.itermcolors"

echo ""
echo "Updating Ghostty colors..."
# Inline color keys spliced between markers in config.ghostty. Inline (not a
# `theme =` file) because Supacode only re-applies inline color keys on live
# reload. Same semantic mapping as the iTerm2 colorscheme above.
GHOSTTY_CONFIG="$DOTFILES_DIR/config/ghostty/config.ghostty"
GHOSTTY_COLORS="$(cat << EOF
palette = 0=$COLOR_BG
palette = 1=$COLOR_MAGENTA
palette = 2=$COLOR_CYAN
palette = 3=$COLOR_YELLOW
palette = 4=$COLOR_PURPLE
palette = 5=$COLOR_MAGENTA
palette = 6=$COLOR_CYAN
palette = 7=$COLOR_FG
palette = 8=$COLOR_MUTED
palette = 9=$COLOR_MAGENTA
palette = 10=$COLOR_CYAN
palette = 11=$COLOR_YELLOW
palette = 12=$COLOR_PURPLE
palette = 13=$COLOR_MAGENTA
palette = 14=$COLOR_CYAN
palette = 15=$COLOR_FG
background = $COLOR_BG
foreground = $COLOR_FG
cursor-color = $COLOR_YELLOW
cursor-text = $COLOR_BG
selection-background = $COLOR_MAGENTA2
selection-foreground = $COLOR_FG
EOF
)"
awk -v block="$GHOSTTY_COLORS" '
  /^# >>> bake-colors:ghostty-colors/ { print; print block; skip=1; next }
  /^# <<< bake-colors:ghostty-colors/ { skip=0 }
  !skip { print }
' "$GHOSTTY_CONFIG" > "$GHOSTTY_CONFIG.tmp" && mv "$GHOSTTY_CONFIG.tmp" "$GHOSTTY_CONFIG"
echo "  Updated: config/ghostty/config.ghostty (between markers)"

echo ""
echo "Updating Claude Code theme..."
mkdir -p "$DOTFILES_DIR/config/claude/themes"
cat > "$DOTFILES_DIR/config/claude/themes/lad1337-neon.json" << EOF
{
  "name": "lad1337 Neon",
  "base": "dark",
  "overrides": {
    "claude": "$COLOR_MAGENTA",
    "text": "$COLOR_FG",
    "inactive": "$COLOR_MUTED",
    "error": "$COLOR_MAGENTA",
    "success": "$COLOR_GREEN",
    "warning": "$COLOR_YELLOW",
    "permission": "$COLOR_CYAN",
    "planMode": "$COLOR_PURPLE",
    "thinking": "$COLOR_PURPLE",
    "link": "$COLOR_CYAN",
    "selection": "$COLOR_MAGENTA2",
    "cursor": "$COLOR_YELLOW",
    "promptBorder": "$COLOR_MAGENTA2",
    "bashBorder": "$COLOR_MAGENTA",
    "autoAccept": "$COLOR_CYAN",
    "diffAdded": "$COLOR_GREEN",
    "diffRemoved": "$COLOR_MAGENTA",
    "diffAddedWord": "$COLOR_CYAN",
    "diffRemovedWord": "$COLOR_MAGENTA2"
  }
}
EOF
echo "  Updated: config/claude/themes/lad1337-neon.json"

echo ""
echo "Done! Colors baked into:"
echo "  - Git (delta, status, branch, decorate)"
echo "  - lazygit"
echo "  - k9s"
echo "  - bat"
echo "  - iTerm2"
echo "  - Ghostty"
echo "  - Claude Code"
echo ""
echo "Note: Restart apps to see changes."
echo "      For iTerm2 run: open config/iterm/tokyonight-1337.itermcolors"
