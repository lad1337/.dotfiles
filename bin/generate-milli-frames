#!/usr/bin/env python3
"""
Generate milli.nvim animation frames from ASCII art using lolcrab.
Parses ANSI escape codes and converts to milli's color format.
"""

import argparse
import subprocess
import sys
import re
import os

# Custom gradient based on colors.sh palette
CUSTOM_GRADIENTS = {
    'lad1337': '#00ffb7, #EDFF00, #ff0e82, #cba6f7, #00ffb7',  # cyan → yellow → magenta → purple → cyan
}

def parse_ansi_to_colors(ansi_line):
    """Parse ANSI escape sequences and extract color runs."""
    # Pattern to match ANSI 24-bit color codes: \x1b[38;2;R;G;Bm
    ansi_pattern = re.compile(r'\x1b\[38;2;(\d+);(\d+);(\d+)m')
    reset_pattern = re.compile(r'\x1b\[39m|\x1b\[0m')

    colors = []
    plain_text = ""
    current_color = None
    current_start = 0
    pos = 0
    i = 0

    while i < len(ansi_line):
        # Check for ANSI color code
        match = ansi_pattern.match(ansi_line, i)
        if match:
            r, g, b = int(match.group(1)), int(match.group(2)), int(match.group(3))
            hex_color = f"#{r:02x}{g:02x}{b:02x}"

            # Save previous color run if exists
            if current_color and pos > current_start:
                colors.append((current_start, pos, current_color))

            current_color = hex_color
            current_start = pos
            i = match.end()
            continue

        # Check for reset code
        reset_match = reset_pattern.match(ansi_line, i)
        if reset_match:
            if current_color and pos > current_start:
                colors.append((current_start, pos, current_color))
            current_color = None
            current_start = pos
            i = reset_match.end()
            continue

        # Check for other escape sequences (skip them)
        if ansi_line[i:i+2] == '\x1b[':
            # Find the end of the escape sequence
            j = i + 2
            while j < len(ansi_line) and ansi_line[j] not in 'mKHJ':
                j += 1
            i = j + 1 if j < len(ansi_line) else j
            continue

        # Regular character - track byte position for Neovim
        char = ansi_line[i]
        plain_text += char
        pos += len(char.encode('utf-8'))  # Use byte length, not char count
        i += 1

    # Save final color run
    if current_color and pos > current_start:
        colors.append((current_start, pos, current_color))

    return plain_text, colors


def generate_frames(input_file, num_frames, angle=45, spread=50, seed=None, gradient='rainbow'):
    """Generate colorized frames using lolcrab with different offsets."""
    frames = []
    colors = []

    with open(input_file, 'r') as f:
        original_text = f.read()

    # Check if gradient is a custom one or a preset
    custom_gradient = CUSTOM_GRADIENTS.get(gradient)

    for i in range(num_frames):
        offset = i / num_frames

        # Build lolcrab command
        cmd = ['lolcrab', '--linear', '--angle', str(angle),
               '--spread', str(spread), '--offset', str(offset)]

        if custom_gradient:
            cmd.extend(['--custom', custom_gradient])
        else:
            cmd.extend(['--gradient', gradient])

        if seed is not None:
            cmd.extend(['--seed', str(seed)])

        result = subprocess.run(
            cmd,
            input=original_text,
            capture_output=True,
            text=True
        )

        frame_lines = []
        frame_colors = []

        for line in result.stdout.split('\n'):
            plain, line_colors = parse_ansi_to_colors(line)
            frame_lines.append(plain)
            # Convert to milli format: {start, end, "#hex", "NONE"}
            frame_colors.append([(s, e, c, "NONE") for s, e, c in line_colors])

        frames.append(frame_lines)
        colors.append(frame_colors)
        print(f"  Frame {i+1}/{num_frames} (offset: {offset:.2f})", file=sys.stderr)

    return frames, colors


def write_lua_file(output_file, frames, colors, delays, cols, rows):
    """Write milli-compatible lua file."""
    with open(output_file, 'w') as f:
        # Header
        f.write("-- Generated by generate-milli-frames\n")
        f.write("-- Animation frames colorized with lolcrab\n")
        delays_str = ", ".join(str(d) for d in delays)
        f.write(f"local M = {{ cols = {cols}, rows = {rows}, delays = {{ {delays_str} }} }}\n\n")

        # Frames
        f.write("M.frames = {}\n")
        for i, frame in enumerate(frames, 1):
            f.write(f"M.frames[{i}] = (function() return {{\n")
            for line in frame:
                # Escape backslashes and quotes
                escaped = line.replace('\\', '\\\\').replace('"', '\\"')
                f.write(f'  "{escaped}",\n')
            f.write("} end)()\n")

        # Colors
        f.write("\nM.colors = {}\n")
        for i, frame_colors in enumerate(colors, 1):
            f.write(f"M.colors[{i}] = (function() return {{\n")
            for row_colors in frame_colors:
                if row_colors:
                    runs = ", ".join(f'{{{s},{e},"{c}","{attr}"}}' for s, e, c, attr in row_colors)
                    f.write(f"  {{ {runs} }},\n")
                else:
                    f.write("  {},\n")
            f.write("} end)()\n")

        f.write("\nreturn M\n")


def main():
    parser = argparse.ArgumentParser(
        description='Generate milli.nvim animation frames from ASCII art using lolcrab.'
    )
    parser.add_argument('input', help='ASCII art file to colorize')
    parser.add_argument('output', help='Output lua file for milli.nvim')
    parser.add_argument('--frames', '-n', type=int, default=10,
                        help='Number of animation frames (default: 10)')
    parser.add_argument('--delay', '-d', type=int, default=100,
                        help='Delay between frames in ms (default: 100)')
    parser.add_argument('--angle', '-a', type=int, default=45,
                        help='Gradient angle in degrees 0-360 (default: 45)')
    parser.add_argument('--spread', '-s', type=int, default=50,
                        help='Gradient spread 0-100 (default: 50)')
    parser.add_argument('--seed', '-S', type=int, default=None,
                        help='Random seed for reproducibility')
    parser.add_argument('--gradient', '-g', default='rainbow',
                        help='Gradient preset name or custom: lad1337 (default: rainbow)')

    args = parser.parse_args()

    if not os.path.exists(args.input):
        print(f"Error: Input file '{args.input}' not found", file=sys.stderr)
        sys.exit(1)

    # Get dimensions
    with open(args.input, 'r') as f:
        lines = f.readlines()
    rows = len(lines)
    cols = max(len(line.rstrip('\n')) for line in lines) if lines else 0

    print(f"Generating {args.frames} frames from {args.input} ({cols} x {rows})", file=sys.stderr)
    print(f"  Linear mode: angle={args.angle}°, spread={args.spread}, gradient={args.gradient}", file=sys.stderr)
    if args.seed is not None:
        print(f"  Seed: {args.seed}", file=sys.stderr)

    frames, colors = generate_frames(
        args.input, args.frames, args.angle, args.spread, args.seed, args.gradient
    )
    delays = [args.delay] * args.frames

    write_lua_file(args.output, frames, colors, delays, cols, rows)
    print(f"Generated {args.output}", file=sys.stderr)


if __name__ == "__main__":
    main()
